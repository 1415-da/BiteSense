# Production UI: static build + nginx (same-origin optional; default API URL from build arg for browser).
FROM node:22-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY index.html vite.config.ts tsconfig.json tsconfig.app.json tsconfig.node.json eslint.config.js ./
COPY src ./src
COPY public ./public
# Empty = browser uses same-origin /api (nginx proxies to the api service in Compose).
ARG VITE_PUBLIC_API_BASE_URL=
ENV VITE_PUBLIC_API_BASE_URL=$VITE_PUBLIC_API_BASE_URL
RUN npm run build

FROM nginx:1.27-alpine
COPY nginx.ui.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
